{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atflow.dev/schemas/funnel-app.schema.json",
  "title": "Tailscale Funnel App Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["appName", "port"],
  "properties": {
    "appName": {
      "type": "string",
      "minLength": 1
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "cwd": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "startupWaitSeconds": {
      "type": "integer",
      "minimum": 1,
      "default": 15
    },
    "healthcheckPath": {
      "type": "string",
      "default": "/"
    },
    "healthcheckUrl": {
      "type": "string"
    },
    "logPath": {
      "type": "string"
    },
    "pidFile": {
      "type": "string"
    },
    "funnel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "https": {
          "type": "boolean",
          "default": true
        },
        "hostname": {
          "type": "string"
        },
        "background": {
          "type": "boolean",
          "default": true
        },
        "anchor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 80
            },
            "https": {
              "type": "boolean",
              "default": false
            },
            "background": {
              "type": "boolean",
              "default": true
            }
          }
        }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    }
  }
}
