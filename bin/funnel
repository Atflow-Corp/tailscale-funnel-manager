#!/usr/bin/env bash
set -euo pipefail

TAILSCALE_BIN="${TAILSCALE_BIN:-/Applications/Tailscale.app/Contents/MacOS/Tailscale}"

usage() {
  cat <<USAGE
Usage:
  funnel up <config.json>
  funnel down <config.json>
  funnel status <config.json>
USAGE
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing command: $1" >&2
    exit 1
  }
}

json_get() {
  local expr="$1"
  local file="$2"
  python3 - "$expr" "$file" <<'PY'
import json, sys
expr = sys.argv[1]
path = expr.split('.') if expr else []
with open(sys.argv[2], 'r', encoding='utf-8') as f:
    data = json.load(f)
cur = data
for part in path:
    if not part:
        continue
    if isinstance(cur, dict) and part in cur:
        cur = cur[part]
    else:
        print("")
        raise SystemExit(0)
if isinstance(cur, bool):
    print("true" if cur else "false")
elif cur is None:
    print("")
else:
    print(cur)
PY
}

wait_for_port() {
  local port="$1"
  local max_wait="$2"
  local i
  for ((i=1; i<=max_wait; i++)); do
    if lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

open_funnel() {
  local port="$1"
  local https="$2"
  local bg="$3"
  local cmd=("$TAILSCALE_BIN" funnel)
  [[ "$bg" == "true" ]] && cmd+=(--bg)
  [[ "$https" == "true" ]] && cmd+=(--https "$port" "$port") || cmd+=("$port")
  "${cmd[@]}"
}

ensure_anchor_funnel() {
  local config="$1"
  local enabled port https bg
  enabled="$(json_get funnel.anchor.enabled "$config")"
  port="$(json_get funnel.anchor.port "$config")"
  https="$(json_get funnel.anchor.https "$config")"
  bg="$(json_get funnel.anchor.background "$config")"

  [[ -z "$enabled" ]] && enabled=true
  [[ "$enabled" != "true" ]] && return 0
  [[ -z "$port" ]] && port=80
  [[ -z "$https" ]] && https=false
  [[ -z "$bg" ]] && bg=true

  echo "==> ensuring anchor funnel on port $port"
  open_funnel "$port" "$https" "$bg"
}

start_app() {
  local config="$1"
  local command cwd log_path pid_file
  command="$(json_get command "$config")"
  cwd="$(json_get cwd "$config")"
  log_path="$(json_get logPath "$config")"
  pid_file="$(json_get pidFile "$config")"

  [[ -z "$command" ]] && return 0
  [[ -z "$cwd" ]] && cwd="$(pwd)"
  [[ -z "$log_path" ]] && log_path="/tmp/funnel-$(json_get appName "$config").log"
  [[ -z "$pid_file" ]] && pid_file="/tmp/funnel-$(json_get appName "$config").pid"

  (
    cd "$cwd"
    nohup sh -lc "$command" >>"$log_path" 2>&1 &
    echo $! >"$pid_file"
  )

  echo "app started, pid file: $pid_file"
}

stop_app() {
  local config="$1"
  local pid_file pid
  pid_file="$(json_get pidFile "$config")"
  [[ -z "$pid_file" ]] && pid_file="/tmp/funnel-$(json_get appName "$config").pid"
  if [[ -f "$pid_file" ]]; then
    pid="$(cat "$pid_file")"
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill "$pid"
      echo "stopped app pid $pid"
    fi
    rm -f "$pid_file"
  fi
}

main() {
  require_cmd python3
  require_cmd lsof
  [[ -x "$TAILSCALE_BIN" ]] || {
    echo "tailscale binary not found: $TAILSCALE_BIN" >&2
    exit 1
  }

  local action="${1:-}"
  local config="${2:-}"
  [[ -n "$action" && -n "$config" ]] || { usage; exit 1; }
  [[ -f "$config" ]] || { echo "config not found: $config" >&2; exit 1; }

  local app_name port startup_wait https bg
  app_name="$(json_get appName "$config")"
  port="$(json_get port "$config")"
  startup_wait="$(json_get startupWaitSeconds "$config")"
  https="$(json_get funnel.https "$config")"
  bg="$(json_get funnel.background "$config")"

  [[ -z "$startup_wait" ]] && startup_wait=15
  [[ -z "$https" ]] && https=false
  [[ -z "$bg" ]] && bg=true

  case "$action" in
    up)
      echo "==> starting $app_name on port $port"
      ensure_anchor_funnel "$config"
      start_app "$config"
      if wait_for_port "$port" "$startup_wait"; then
        echo "==> opening tailscale funnel"
        open_funnel "$port" "$https" "$bg"
        "$TAILSCALE_BIN" funnel status
      else
        echo "port $port did not become ready within ${startup_wait}s" >&2
        exit 1
      fi
      ;;
    down)
      echo "==> resetting tailscale funnel"
      "$TAILSCALE_BIN" funnel reset
      stop_app "$config"
      "$TAILSCALE_BIN" funnel status || true
      ;;
    status)
      echo "==> status for $app_name"
      lsof -nP -iTCP:"$port" -sTCP:LISTEN || true
      "$TAILSCALE_BIN" funnel status
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
