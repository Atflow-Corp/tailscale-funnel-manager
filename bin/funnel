#!/usr/bin/env bash
set -euo pipefail

TAILSCALE_BIN="${TAILSCALE_BIN:-/Applications/Tailscale.app/Contents/MacOS/Tailscale}"

usage() {
  cat <<USAGE
Usage:
  funnel up <config.json>
  funnel down <config.json>
  funnel status <config.json>

Config schema: schemas/funnel-app.schema.json
  - 최상위 "anchor" (선택): config 단위로 1개만 기동
  - 최상위 "apps" (필수, 배열): 각 원소가 하나의 앱/funnel
USAGE
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing command: $1" >&2
    exit 1
  }
}

# json_plan: config 파일을 파싱해서 line 단위 key=value 형태 plan을 stdout으로 출력.
# 이후 bash가 단순히 읽고 반복만 하면 되도록 python에서 모든 기본값/정규화를 끝낸다.
json_plan() {
  local config="$1"
  python3 - "$config" <<'PY'
import json, sys, base64, shlex

def b(v, default):
    if v is None:
        return "true" if default else "false"
    return "true" if bool(v) else "false"

def s(v, default=""):
    if v is None:
        return default
    return str(v)

def emit(key, value):
    # shlex.quote로 감싸서 eval 안전성 확보
    print(f"{key}={shlex.quote(str(value))}")

with open(sys.argv[1], "r", encoding="utf-8") as f:
    cfg = json.load(f)

anchor = cfg.get("anchor") or {}
anchor_enabled = bool(anchor.get("enabled", False))
emit("ANCHOR_ENABLED", b(anchor_enabled, False))
emit("ANCHOR_PORT", s(anchor.get("port", 80)))
emit("ANCHOR_HTTPS", b(anchor.get("https"), True))
emit("ANCHOR_BG", b(anchor.get("background"), True))

apps = cfg.get("apps") or []
emit("APP_COUNT", len(apps))
for i, app in enumerate(apps):
    name = s(app.get("appName", f"app{i}"))
    port = s(app.get("port", ""))
    cwd = s(app.get("cwd", ""))
    command = s(app.get("command", ""))
    wait = s(app.get("startupWaitSeconds", 15))
    log_path = s(app.get("logPath", "")) or f"/tmp/funnel-{name}.log"
    pid_file = s(app.get("pidFile", "")) or f"/tmp/funnel-{name}.pid"
    funnel = app.get("funnel") or {}
    https = b(funnel.get("https"), True)
    bg = b(funnel.get("background"), True)
    # command는 base64로 보존 (공백/따옴표 escape 안전)
    cmd_b64 = base64.b64encode(command.encode("utf-8")).decode("ascii")
    emit(f"APP_{i}_NAME", name)
    emit(f"APP_{i}_PORT", port)
    emit(f"APP_{i}_CWD", cwd)
    emit(f"APP_{i}_CMD_B64", cmd_b64)
    emit(f"APP_{i}_WAIT", wait)
    emit(f"APP_{i}_LOG", log_path)
    emit(f"APP_{i}_PID", pid_file)
    emit(f"APP_{i}_HTTPS", https)
    emit(f"APP_{i}_BG", bg)
PY
}

wait_for_port() {
  local port="$1"
  local max_wait="$2"
  local i
  for ((i=1; i<=max_wait; i++)); do
    if lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

open_funnel() {
  local port="$1"
  local https="$2"
  local bg="$3"
  local cmd=("$TAILSCALE_BIN" funnel)
  [[ "$bg" == "true" ]] && cmd+=(--bg)
  if [[ "$https" == "true" ]]; then
    cmd+=(--https "$port" "$port")
  else
    cmd+=("$port")
  fi
  "${cmd[@]}"
}

ensure_anchor_funnel() {
  if [[ "$ANCHOR_ENABLED" != "true" ]]; then
    return 0
  fi
  echo "==> ensuring anchor funnel on port $ANCHOR_PORT (https=$ANCHOR_HTTPS, bg=$ANCHOR_BG)"
  open_funnel "$ANCHOR_PORT" "$ANCHOR_HTTPS" "$ANCHOR_BG"
}

start_app() {
  local idx="$1"
  local name="APP_${idx}_NAME"; name="${!name}"
  local cwd="APP_${idx}_CWD"; cwd="${!cwd}"
  local cmd_b64="APP_${idx}_CMD_B64"; cmd_b64="${!cmd_b64}"
  local log_path="APP_${idx}_LOG"; log_path="${!log_path}"
  local pid_file="APP_${idx}_PID"; pid_file="${!pid_file}"

  local command
  command="$(printf '%s' "$cmd_b64" | base64 -d)"

  if [[ -z "$command" ]]; then
    echo "   ($name) no command — skipping process launch"
    return 0
  fi

  [[ -z "$cwd" ]] && cwd="$(pwd)"

  echo "==> starting app: $name (cwd=$cwd, log=$log_path, pid=$pid_file)"
  # python3 런처로 새 세션/프로세스 그룹(setsid)에서 앱을 띄운다.
  # 저장되는 PID가 곧 PGID가 되므로, stop_app에서 `kill -TERM -<pid>` 한 번으로
  # sh/pnpm/node 등 자식 프로세스 트리 전체를 깔끔하게 정리할 수 있다.
  python3 - "$command" "$cwd" "$log_path" "$pid_file" <<'PY'
import os, sys

command, cwd, log_path, pid_file = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

# fork 후 자식을 setsid()로 새 세션/그룹 리더로 승격시키고,
# 자식은 sh -lc "$command"를 exec하여 그 프로세스가 그룹 리더가 되도록 한다.
# 이렇게 띄움으로써 PGID == 저장된 PID 이 되고,
# stop_app에서 `kill -TERM -<pid>` 한 번으로 sh/pnpm/node 자식까지 정리 가능.
pid = os.fork()
if pid > 0:
    # 부모(런처): pid_file에 자식 PID(=PGID) 기록 후 즉시 종료
    with open(pid_file, 'w') as f:
        f.write(str(pid) + '\n')
    os._exit(0)

# 자식: 새 세션 + 새 프로세스 그룹 리더
os.setsid()

# stdio 재배치: stdin=/dev/null, stdout/stderr=log_path (append)
null_fd = os.open(os.devnull, os.O_RDONLY)
log_fd = os.open(log_path, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o644)
os.dup2(null_fd, 0)
os.dup2(log_fd, 1)
os.dup2(log_fd, 2)
os.close(null_fd)
os.close(log_fd)

if cwd:
    os.chdir(cwd)

# exec로 바꿔치기 — 이 프로세스가 그룹 리더이며 PID는 부모가 기록한 값과 동일.
os.execvp('sh', ['sh', '-lc', command])
PY
}

stop_app() {
  local idx="$1"
  local name="APP_${idx}_NAME"; name="${!name}"
  local pid_file="APP_${idx}_PID"; pid_file="${!pid_file}"
  if [[ ! -f "$pid_file" ]]; then
    return 0
  fi
  local pid
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ -z "$pid" ]]; then
    rm -f "$pid_file"
    return 0
  fi

  # start_app에서 setsid로 띄웠으므로 PGID = PID.
  # `kill -TERM -<pid>` (음수 부호 = 그룹 시그널)로 sh/pnpm/node 자식까지 한 번에 정리.
  if kill -0 "$pid" >/dev/null 2>&1; then
    kill -TERM -"$pid" >/dev/null 2>&1 || kill -TERM "$pid" >/dev/null 2>&1 || true
    # 자식 정리 대기 (최대 5초)
    local i
    for ((i=0; i<10; i++)); do
      kill -0 "$pid" >/dev/null 2>&1 || break
      sleep 0.5
    done
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill -KILL -"$pid" >/dev/null 2>&1 || kill -KILL "$pid" >/dev/null 2>&1 || true
    fi
    echo "   stopped $name (pid $pid)"
  fi
  rm -f "$pid_file"
}

cmd_up() {
  # up 시작 전 항상 down으로 초기화: tailscale funnel reset + 기존 앱 프로세스 그룹 정리.
  # 이전 up이 비정상 종료되었거나 stale한 PID/funnel 상태가 남아있어도
  # 깨끗한 상태에서 기동을 시작하도록 보장한다.
  echo "==> [up] 시작 전 reset 수행: tailscale funnel reset + 기존 앱 정리"
  cmd_down >&2 || true
  echo "==> [up] reset 완료, 본 기동 시작"

  ensure_anchor_funnel

  local successful_apps=()
  local failed_apps=()
  local failed_reasons=()

  local i
  for ((i=0; i<APP_COUNT; i++)); do
    local name="APP_${i}_NAME"; name="${!name}"
    local port="APP_${i}_PORT"; port="${!port}"
    local wait_s="APP_${i}_WAIT"; wait_s="${!wait_s}"
    local https="APP_${i}_HTTPS"; https="${!https}"
    local bg="APP_${i}_BG"; bg="${!bg}"

    start_app "$i"

    echo "==> waiting for $name on port $port (up to ${wait_s}s)"
    if ! wait_for_port "$port" "$wait_s"; then
      echo "!! $name: port $port did not become ready within ${wait_s}s — 앱 프로세스 정리 후 다음 앱으로 진행" >&2
      stop_app "$i" || true
      failed_apps+=("$name")
      failed_reasons+=("port $port ready timeout (앱 프로세스 정리됨)")
      continue
    fi

    echo "==> opening funnel for $name (port=$port, https=$https, bg=$bg)"
    if ! open_funnel "$port" "$https" "$bg"; then
      echo "!! $name: tailscale funnel open failed — 앱 프로세스는 유지하고 다음 앱으로 진행" >&2
      failed_apps+=("$name")
      failed_reasons+=("tailscale funnel open failed (앱 프로세스는 유지)")
      continue
    fi

    successful_apps+=("$name")
  done

  # --- summary ---
  local succ_n="${#successful_apps[@]}"
  local fail_n="${#failed_apps[@]}"
  echo ""
  echo "==> 기동 결과: 성공 ${succ_n} / 실패 ${fail_n}"
  local s
  if ((succ_n > 0)); then
    for s in "${successful_apps[@]}"; do
      echo "    ✓ $s"
    done
  fi
  local k
  for ((k=0; k<fail_n; k++)); do
    echo "    ✗ ${failed_apps[$k]} (${failed_reasons[$k]})" >&2
  done

  # 현행과 동일하게 마지막에 funnel status 한 번 출력 (best-effort)
  "$TAILSCALE_BIN" funnel status || true

  # exit code
  if [[ "$APP_COUNT" -eq 0 ]]; then
    return 0
  fi
  if [[ "$succ_n" -eq 0 && "$fail_n" -gt 0 ]]; then
    exit 1
  fi
  return 0
}

cmd_down() {
  echo "==> resetting tailscale funnel"
  "$TAILSCALE_BIN" funnel reset || true

  local i
  # 역순으로 정리
  for ((i=APP_COUNT-1; i>=0; i--)); do
    stop_app "$i"
  done

  "$TAILSCALE_BIN" funnel status || true
}

cmd_status() {
  local i
  for ((i=0; i<APP_COUNT; i++)); do
    local name="APP_${i}_NAME"; name="${!name}"
    local port="APP_${i}_PORT"; port="${!port}"
    echo "==> $name (port $port)"
    lsof -nP -iTCP:"$port" -sTCP:LISTEN || true
  done
  echo "==> tailscale funnel status"
  "$TAILSCALE_BIN" funnel status || true
}

main() {
  require_cmd python3
  require_cmd lsof
  [[ -x "$TAILSCALE_BIN" ]] || {
    echo "tailscale binary not found: $TAILSCALE_BIN" >&2
    exit 1
  }

  local action="${1:-}"
  local config="${2:-}"
  [[ -n "$action" && -n "$config" ]] || { usage; exit 1; }
  [[ -f "$config" ]] || { echo "config not found: $config" >&2; exit 1; }

  # plan을 한번에 파싱해서 쉘 변수로 로드 (python이 shlex.quote로 이미 감싸둔 상태)
  local plan
  plan="$(json_plan "$config")"
  eval "$(printf '%s\n' "$plan" | sed 's/^/export /')"

  case "$action" in
    up) cmd_up ;;
    down) cmd_down ;;
    status) cmd_status ;;
    *) usage; exit 1 ;;
  esac
}

main "$@"
